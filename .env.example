# Database configuration (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=fitnova_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy Database URL
# For local running outside docker, host might be localhost. Inside docker-compose, host is 'db'.
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/fitnova_db

# LLM Providers API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Application Settings
APP_ENV=development
API_URL=http://api:8000
